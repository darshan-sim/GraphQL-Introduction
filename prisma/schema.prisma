// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Link {
  id          Int       @id @default(autoincrement())
  description String
  url         String
  createdAt   DateTime  @default(now())
  comments    Comment[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  body      String
  linkId    Int
  link      Link     @relation(fields: [linkId], references: [id])
}
